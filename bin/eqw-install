#!/usr/bin/env node

/**
 * Everything Qwen Code - Global Installer
 * 
 * Installs ECC agents, skills, commands, hooks, rules, and MCP configs
 * to the user's global ~/.qwen/ directory for use across all workspaces.
 * 
 * Usage: npx eqw-install
 */

const fs = require('fs');
const path = require('path');
const os = require('os');

// ANSI colors for terminal output
const colors = {
  reset: '\x1b[0m',
  bright: '\x1b[1m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  red: '\x1b[31m',
  cyan: '\x1b[36m'
};

function log(message, color = 'reset') {
  console.log(`${colors[color]}${message}${colors.reset}`);
}

function logSuccess(message) {
  log(`✓ ${message}`, 'green');
}

function logInfo(message) {
  log(`ℹ ${message}`, 'blue');
}

function logWarn(message) {
  log(`⚠ ${message}`, 'yellow');
}

function logError(message) {
  log(`✗ ${message}`, 'red');
}

// Get paths
const HOME_DIR = os.homedir();
const QWEN_DIR = path.join(HOME_DIR, '.qwen');
const ECC_DIR = path.join(__dirname, '..');

// Directories to install
const INSTALL_DIRS = [
  { src: '.agents', dest: 'agents', required: true },
  { src: '.qwen/skills', dest: 'skills', required: true },
  { src: '.qwen/commands', dest: 'commands', required: true },
  { src: '.qwen/hooks', dest: 'hooks', required: true },
  { src: '.qwen/rules', dest: 'rules', required: true },
  { src: '.qwen/mcp-configs', dest: 'mcp-configs', required: false },
  { src: 'contexts', dest: 'contexts', required: false }
];

// Config files to install
const CONFIG_FILES = [
  { src: 'agent.yaml', dest: 'agent.yaml', required: false }
];

function ensureDir(dirPath) {
  if (!fs.existsSync(dirPath)) {
    fs.mkdirSync(dirPath, { recursive: true });
    return true;
  }
  return false;
}

async function copyDir(src, dest, relDir, flags) {
  if (!fs.existsSync(src)) {
    return false;
  }

  ensureDir(dest);

  const entries = fs.readdirSync(src, { withFileTypes: true });

  for (const entry of entries) {
    const srcPath = path.join(src, entry.name);
    const destPath = path.join(dest, entry.name);
    const relPath = path.join(relDir, entry.name);

    if (entry.isDirectory()) {
      await copyDir(srcPath, destPath, relPath, flags);
    } else {
      const result = copyFile(srcPath, destPath, relPath, flags);

      if (result === 'prompt') {
        const action = await showDiffPrompt(relPath, srcPath, destPath, flags);

        switch (action) {
          case 'overwrite':
            if (flags.backup) {
              fs.copyFileSync(destPath, destPath + '.bak');
            }
            if (!flags.dryRun) {
              fs.copyFileSync(srcPath, destPath);
            }
            logSuccess(`Overwritten: ${relPath}`);
            break;
          case 'all-overwrite':
            flags.force = true;
            if (flags.backup) {
              fs.copyFileSync(destPath, destPath + '.bak');
            }
            if (!flags.dryRun) {
              fs.copyFileSync(srcPath, destPath);
            }
            logSuccess(`Overwritten: ${relPath}`);
            break;
          case 'skip':
            logInfo(`Skipped: ${relPath} (keeping local)`);
            break;
          case 'quit':
            logWarn('Installation aborted by user');
            process.exit(0);
            break;
        }
      } else if (result) {
        // Copied or identical — no action needed
      } else {
        logError(`Failed to install: ${relPath}`);
      }
    }
  }

  return true;
}

function copyFile(src, dest, relPath, flags) {
  if (!fs.existsSync(src)) {
    return false;
  }

  // Destination doesn't exist — copy directly
  if (!fs.existsSync(dest)) {
    if (!flags.dryRun) {
      fs.copyFileSync(src, dest);
    }
    return true;
  }

  // Files are identical — skip
  if (!filesDiffer(src, dest)) {
    return true;
  }

  // Files differ
  if (flags.force) {
    if (flags.backup) {
      fs.copyFileSync(dest, dest + '.bak');
    }
    if (!flags.dryRun) {
      fs.copyFileSync(src, dest);
    }
    return true;
  }

  // Needs interactive prompt
  return 'prompt';
}

function mergeJsonFiles(existing, incoming) {
  if (!fs.existsSync(existing)) {
    return copyFile(incoming, existing, path.basename(incoming), { force: true, backup: false, dryRun: false });
  }

  try {
    const existingData = JSON.parse(fs.readFileSync(existing, 'utf8'));
    const incomingData = JSON.parse(fs.readFileSync(incoming, 'utf8'));

    // Merge MCP servers
    if (incomingData.mcpServers && existingData.mcpServers) {
      existingData.mcpServers = {
        ...existingData.mcpServers,
        ...incomingData.mcpServers
      };
    } else if (incomingData.mcpServers) {
      existingData.mcpServers = incomingData.mcpServers;
    }

    fs.writeFileSync(existing, JSON.stringify(existingData, null, 2) + '\n');
    return true;
  } catch (err) {
    logError(`Error merging ${existing}: ${err.message}`);
    return false;
  }
}

/**
 * Check if two files have different content.
 * Returns true if files differ.
 */
function filesDiffer(src, dest) {
  if (!fs.existsSync(dest)) return true;
  try {
    const srcContent = fs.readFileSync(src);
    const destContent = fs.readFileSync(dest);
    return !srcContent.equals(destContent);
  } catch (err) {
    return true; // If we can't read, assume different
  }
}

/**
 * Format bytes to human-readable size.
 */
function formatSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

/**
 * Generate a simple unified diff between two files (first 15 lines).
 */
function showUnifiedDiff(src, dest) {
  try {
    const srcLines = fs.readFileSync(src, 'utf8').split('\n');
    const destLines = fs.readFileSync(dest, 'utf8').split('\n');
    const maxLen = Math.max(srcLines.length, destLines.length);
    const diffLines = [];

    for (let i = 0; i < Math.min(maxLen, 30); i++) {
      const srcLine = srcLines[i] || '';
      const destLine = destLines[i] || '';
      if (srcLine !== destLine) {
        if (destLine) diffLines.push(`- ${destLine}`);
        if (srcLine) diffLines.push(`+ ${srcLine}`);
      }
    }

    if (diffLines.length === 0) return '  (no visible diff)';
    return diffLines.slice(0, 15).join('\n') +
      (diffLines.length > 15 ? '\n  ...' : '');
  } catch (err) {
    return '  (could not generate diff)';
  }
}

/**
 * Parse CLI arguments for flags.
 * Returns { force: bool, backup: bool, dryRun: bool }
 */
function parseArgs(argv) {
  return {
    force: argv.includes('--force'),
    backup: argv.includes('--backup'),
    dryRun: argv.includes('--dry-run'),
  };
}

/**
 * Check if stdin is a TTY (interactive terminal).
 */
function isInteractive() {
  return process.stdin.isTTY;
}

/**
 * Interactive prompt for file conflicts.
 * Always returns a Promise resolving to: 'overwrite' | 'skip' | 'all-overwrite' | 'quit'
 */
function showDiffPrompt(relPath, src, dest, flags) {
  return new Promise((resolve) => {
    try {
      const srcStat = fs.statSync(src);
      const destStat = fs.statSync(dest);
      const srcSize = formatSize(srcStat.size);
      const destSize = formatSize(destStat.size);

      log(`\n⚠ File differs: ${relPath}`, 'yellow');
      log(`  Local: ${destSize} | Incoming: ${srcSize}`, 'yellow');
    } catch (err) {
      logWarn(`Cannot stat files for diff prompt: ${relPath}`);
      resolve('skip');
      return;
    }

    if (flags && flags.dryRun) {
      log('  [DRY RUN] Would overwrite', 'cyan');
      resolve('skip');
      return;
    }

    if (!isInteractive()) {
      logWarn(`Non-interactive mode: skipping ${relPath}`);
      resolve('skip');
      return;
    }

    const readline = require('readline');
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout
    });

    const ask = () => {
      rl.question('  [O]verwrite  [S]kip  [D]iff  [A]ll overwrite  [Q]uit\n  > ', (answer) => {
        try {
          const choice = answer.trim().toLowerCase();
          switch (choice) {
            case 'o':
              rl.close();
              resolve('overwrite');
              break;
            case 's':
              rl.close();
              resolve('skip');
              break;
            case 'd':
              try {
                const diff = showUnifiedDiff(src, dest);
                log(`\n${diff}\n`, 'cyan');
              } catch (err) {
                logWarn(`Could not generate diff: ${relPath}`);
              }
              ask();
              break;
            case 'a':
              rl.close();
              resolve('all-overwrite');
              break;
            case 'q':
              rl.close();
              resolve('quit');
              break;
            default:
              ask();
              break;
          }
        } catch (err) {
          logWarn(`Error processing input: ${err.message}`);
          ask();
        }
      });
    };
    ask();
  });
}

async function main() {
  const flags = parseArgs(process.argv.slice(2));

  if (flags.force) {
    log('\n⚠ FORCE mode: overwriting all files without prompts\n', 'yellow');
  }
  if (flags.backup) {
    log('\n📦 BACKUP mode: creating .bak files before overwrites\n', 'yellow');
  }
  if (flags.dryRun) {
    log('\n🔍 DRY RUN: showing changes without applying\n', 'yellow');
  }

  log('\n' + '='.repeat(60), 'cyan');
  log('  Everything Qwen Code - Global Installer', 'bright');
  log('  Installing ECC to ~/.qwen/', 'cyan');
  log('='.repeat(60) + '\n', 'cyan');
  
  // Check if .qwen directory exists
  const qwenExists = fs.existsSync(QWEN_DIR);
  
  if (qwenExists) {
    logInfo(`Found existing Qwen directory: ${QWEN_DIR}`);
    
    // Check for existing skills
    const existingSkillsDir = path.join(QWEN_DIR, 'skills');
    if (fs.existsSync(existingSkillsDir)) {
      const existingSkills = fs.readdirSync(existingSkillsDir).filter(f => 
        fs.statSync(path.join(existingSkillsDir, f)).isDirectory()
      );
      if (existingSkills.length > 0) {
        logWarn(`Found ${existingSkills.length} existing skill(s). New skills will be added without overwriting.`);
      }
    }
  } else {
    logInfo(`Creating Qwen directory: ${QWEN_DIR}`);
    ensureDir(QWEN_DIR);
  }
  
  let installedCount = 0;
  let skippedCount = 0;
  
  // Install directories
  log('\n📁 Installing directories...\n', 'bright');
  
  for (const dir of INSTALL_DIRS) {
    const srcPath = path.join(ECC_DIR, dir.src);
    const destPath = path.join(QWEN_DIR, dir.dest);
    
    if (!fs.existsSync(srcPath)) {
      if (dir.required) {
        logError(`Missing required directory: ${dir.src}`);
        process.exit(1);
      } else {
        logWarn(`Optional directory not found: ${dir.src} (skipping)`);
        skippedCount++;
        continue;
      }
    }
    
    // Check if destination exists
    if (fs.existsSync(destPath)) {
      logInfo(`Directory exists: ${dir.dest} (merging new content)`);
    }
    
    if (await copyDir(srcPath, destPath, dir.dest, flags)) {
      logSuccess(`Installed: ${dir.dest}`);
      installedCount++;
    } else {
      logError(`Failed to install: ${dir.dest}`);
    }
  }
  
  // Install config files
  log('\n⚙️  Installing configuration files...\n', 'bright');

  for (const file of CONFIG_FILES) {
    const srcPath = path.join(ECC_DIR, file.src);
    const destPath = path.join(QWEN_DIR, file.dest);

    if (!fs.existsSync(srcPath)) {
      if (file.required) {
        logError(`Missing required config: ${file.src}`);
        process.exit(1);
      } else {
        logWarn(`Optional config not found: ${file.src} (skipping)`);
        skippedCount++;
        continue;
      }
    }

    // Special handling for mcp.json - merge instead of overwrite
    if (file.dest === 'mcp.json') {
      if (mergeJsonFiles(destPath, srcPath)) {
        logSuccess(`Installed/Merged: ${file.dest}`);
        installedCount++;
      } else {
        logError(`Failed to install: ${file.dest}`);
      }
    } else {
      // For other configs, only copy if doesn't exist
      if (fs.existsSync(destPath)) {
        logInfo(`Config exists: ${file.dest} (keeping existing)`);
        skippedCount++;
      } else if (copyFile(srcPath, destPath, file.dest, flags)) {
        logSuccess(`Installed: ${file.dest}`);
        installedCount++;
      } else {
        logError(`Failed to install: ${file.dest}`);
      }
    }
  }

  // Install token efficiency rules
  log('\n📝 Installing token efficiency rules...\n', 'bright');

  try {
    const { mergeTokenRules } = require('../scripts/merge-token-rules');
    const qwenMdPath = path.join(QWEN_DIR, 'QWEN.md');
    const result = mergeTokenRules(qwenMdPath);

    if (result.action === 'appended') {
      logSuccess('Appended token efficiency rules to QWEN.md');
    } else if (result.action === 'created') {
      logSuccess('Created QWEN.md with token efficiency rules');
    } else {
      logInfo('Token efficiency rules already present in QWEN.md (skipping)');
    }
  } catch (err) {
    logWarn(`Token efficiency installation skipped: ${err.message}`);
  }

  // Configure MCP servers automatically
  log('\n🔌 Configuring MCP servers...\n', 'bright');

  try {
    const { getFreeMcpServers } = require('../scripts/lib/mcp-catalog');
    const { configureMultipleMcpServers } = require('../scripts/lib/mcp-installer');

    const mcpConfigPath = path.join(QWEN_DIR, 'settings.json');
    const freeMcps = getFreeMcpServers(true); // Only recommended free MCPs
    const mcpResults = configureMultipleMcpServers(mcpConfigPath, freeMcps);

    for (const id of mcpResults.installed) {
      logSuccess(`MCP: ${id}`);
    }

    logSuccess(`${mcpResults.installed.length} MCP server(s) configured`);
    if (mcpResults.skipped.length > 0) {
      logInfo(`${mcpResults.skipped.length} MCP server(s) already configured`);
    }
  } catch (err) {
    logWarn(`MCP configuration skipped: ${err.message}`);
    logInfo('You can configure MCPs later with: node scripts/setup-mcp-servers.js --auto');
  }
  
  // Summary
  log('\n' + '='.repeat(60), 'cyan');
  log('  Installation Complete!', 'bright');
  log('='.repeat(60) + '\n', 'cyan');
  
  logSuccess(`${installedCount} component(s) installed`);
  if (skippedCount > 0) {
    logInfo(`${skippedCount} component(s) skipped (already exist or optional)`);
  }
  
  log('\n📍 Installation location:', 'bright');
  log(`   ${QWEN_DIR}\n`, 'green');
  
  log('📚 What\'s included:', 'bright');
  log('   • 36 specialized agents in ~/.qwen/agents/', 'cyan');
  log('   • 151 skills in ~/.qwen/skills/', 'cyan');
  log('   • 68 commands in ~/.qwen/commands/', 'cyan');
  log('   • Automated hooks in ~/.qwen/hooks/', 'cyan');
  log('   • Language rules in ~/.qwen/rules/', 'cyan');
  log('   • MCP configurations in ~/.qwen/settings.json', 'cyan');
  log('   • Token efficiency rules in ~/.qwen/QWEN.md', 'cyan');
  log('   • 11+ free MCP servers auto-configured', 'cyan');
  
  log('\n🚀 Next steps:', 'bright');
  log('   1. Restart Qwen Code to load the new components', 'yellow');
  log('   2. Use /help to see available commands', 'yellow');
  log('   3. Agents will auto-activate based on your tasks', 'yellow');
  
  log('\n🔄 To update later, run:', 'bright');
  log('   npx eqw-install\n', 'yellow');
  
  log('='.repeat(60) + '\n', 'cyan');
}

// Handle errors
process.on('uncaughtException', (err) => {
  logError(`Fatal error: ${err.message}`);
  process.exit(1);
});

main();
